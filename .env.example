# Switch Books — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Public site URL (canonical, with www). Used for the admin magic-link redirect.
NEXT_PUBLIC_SITE_URL=https://www.tryswitchbooks.co.uk

# Supabase — Project Settings → API. Powers the leads dashboard + persistence.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Bypasses Row Level Security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — lead alert emails (the primary way new leads reach you).
# Create a key at resend.com → API Keys. Leave blank to disable email (the
# review still works and still saves to Supabase).
RESEND_API_KEY=
# Where new-lead alerts are sent (your private inbox — never shown publicly).
LEAD_NOTIFY_TO=
# The "from" address (must be a domain you've verified in Resend).
LEAD_NOTIFY_FROM=Switch Books <leads@tryswitchbooks.co.uk>

# Google Analytics 4 Measurement ID (Admin → Data Streams → your web stream).
# Leave blank to disable analytics entirely. Only loads after cookie consent.
NEXT_PUBLIC_GA_ID=

# Set to "true" to show the /coming-soon holding page instead of the live site.
# Leave blank/unset for the full site. Toggle in your hosting env + redeploy.
COMING_SOON=
